{
  "rules": {
    ".read": false,
    ".write": false,
    "siteStats": {
      "visits": {
        ".read": true,
        ".write": "newData.hasChildren(['count', 'updatedAt']) && ((!data.exists() && newData.child('count').val() == 1) || (data.exists() && newData.child('count').val() == data.child('count').val() + 1))",
        "count": {
          ".validate": "newData.isNumber()"
        },
        "updatedAt": {
          ".validate": "newData.isNumber()"
        },
        "$other": {
          ".validate": false
        }
      }
    }
  }
}
