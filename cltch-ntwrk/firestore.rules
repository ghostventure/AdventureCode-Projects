rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isVerifiedAuth() {
      return isAuth() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isVerifiedAuth() && request.auth.uid == userId;
    }

    function hasHostProfile() {
      return isVerifiedAuth()
        && exists(/databases/$(database)/documents/hosts/$(request.auth.uid));
    }

    function hasMusicianProfile() {
      return isVerifiedAuth()
        && exists(/databases/$(database)/documents/musicians/$(request.auth.uid));
    }

    function has(field) {
      return field in request.resource.data;
    }

    function hasOnlyKeys(keys) {
      return request.resource.data.keys().hasOnly(keys);
    }

    function isString(field, maxLen) {
      return has(field)
        && request.resource.data[field] is string
        && request.resource.data[field].size() > 0
        && request.resource.data[field].size() <= maxLen;
    }

    function isOptionalString(field, maxLen) {
      return !has(field)
        || (request.resource.data[field] is string
            && request.resource.data[field].size() <= maxLen);
    }

    function isZip(field) {
      return has(field)
        && request.resource.data[field] is string
        && request.resource.data[field].matches('^[0-9]{5}(-[0-9]{4})?$');
    }

    function isOptionalPhone(field) {
      return !has(field)
        || (request.resource.data[field] is string
            && request.resource.data[field].matches('^[0-9+()\\-\\.\\s]{7,20}$'));
    }

    function isOptionalUrl(field) {
      return !has(field)
        || (request.resource.data[field] is string
            && request.resource.data[field].size() <= 200
            && (
              request.resource.data[field].size() == 0
              || request.resource.data[field].matches('^https?://[^\\s]+$')
            ));
    }

    function isOptionalNumberInRange(field, minVal, maxVal) {
      return !has(field)
        || (request.resource.data[field] is number
            && request.resource.data[field] >= minVal
            && request.resource.data[field] <= maxVal);
    }

    function isOptionalNonNegativeNumber(field) {
      return !has(field)
        || (request.resource.data[field] is number
            && request.resource.data[field] >= 0);
    }

    function isUnchanged(field) {
      return resource.data[field] == request.resource.data[field];
    }

    function sameOrAbsent(field) {
      return (!((field in resource.data)) && !((field in request.resource.data)))
        || ((field in resource.data) && (field in request.resource.data)
            && resource.data[field] == request.resource.data[field]);
    }

    function validPaymentMethodField(field) {
      return has(field)
        && request.resource.data[field] in ['applepay', 'googlepay', 'venmo', 'cashapp', 'zelle', 'paypal', 'ach', 'plaid', 'check'];
    }

    function validPaymentHandle(methodField, handleField) {
      return request.resource.data[methodField] == 'check'
        ? (!has(handleField)
           || (request.resource.data[handleField] is string
               && request.resource.data[handleField].size() <= 100))
        : (has(handleField)
           && request.resource.data[handleField] is string
           && request.resource.data[handleField].size() > 0
           && request.resource.data[handleField].size() <= 100);
    }

    function validHostVenueType() {
      return request.resource.data.venueType in [
        'Bar / Lounge', 'Restaurant', 'Concert Hall', 'Private Event',
        'Festival', 'Hotel', 'Corporate Event', 'Other'
      ];
    }

    function validGenres() {
      return !has('genres')
        || (
          request.resource.data.genres is list
          && request.resource.data.genres.size() <= 15
          && request.resource.data.genres.hasOnly([
            'Jazz', 'R&B / Soul', 'Hip-Hop', 'Blues', 'Rock', 'Country',
            'Classical', 'Electronic', 'House', 'Techno', 'EDM',
            'Afrobeats', 'Reggae', 'Latin', 'Open Format', 'Open / Any',
            'Portrait', 'Editorial', 'Commercial', 'Lifestyle',
            'Event Coverage', 'Fashion', 'Bridal', 'Streetwear'
          ])
        );
    }

    function validExperience() {
      return !has('experience')
        || (
          (request.resource.data.experience is int
            && request.resource.data.experience >= 0
            && request.resource.data.experience <= 80)
          || (request.resource.data.experience is string
            && request.resource.data.experience.matches('^[0-9]{1,2}$'))
        );
    }

    function validListSize(field, maxLen) {
      return !has(field)
        || (request.resource.data[field] is list
            && request.resource.data[field].size() <= maxLen);
    }

    function gigCoreUnchanged() {
      return isUnchanged('hostId')
        && isUnchanged('venue')
        && isUnchanged('location')
        && isUnchanged('genre')
        && isUnchanged('pay')
        && isUnchanged('date')
        && isUnchanged('time')
        && sameOrAbsent('notes')
        && sameOrAbsent('skillNeed')
        && sameOrAbsent('performerType')
        && sameOrAbsent('lat')
        && sameOrAbsent('lng')
        && sameOrAbsent('createdAt')
        && sameOrAbsent('payBaseAmount')
        && sameOrAbsent('processingFeeRate')
        && sameOrAbsent('processingFeeAmount')
        && sameOrAbsent('hostTotalCharge')
        && sameOrAbsent('offerExpiryHours')
        && sameOrAbsent('expiresOn')
        && sameOrAbsent('acceptedAt')
        && sameOrAbsent('lockedPay')
        && sameOrAbsent('lockedDate')
        && sameOrAbsent('lockedTime')
        && sameOrAbsent('lockedLocation')
        && sameOrAbsent('lockedProcessingFeeAmount')
        && sameOrAbsent('lockedHostTotalCharge');
    }

    function validAcceptanceLock() {
      return has('acceptedAt')
        && request.resource.data.acceptedAt is timestamp
        && isString('lockedPay', 100)
        && isString('lockedDate', 20)
        && isString('lockedTime', 10)
        && isString('lockedLocation', 100)
        && request.resource.data.lockedPay == request.resource.data.pay
        && request.resource.data.lockedDate == request.resource.data.date
        && request.resource.data.lockedTime == request.resource.data.time
        && request.resource.data.lockedLocation == request.resource.data.location
        && (
          (!has('lockedProcessingFeeAmount') && !has('processingFeeAmount'))
          || (
            has('lockedProcessingFeeAmount')
            && has('processingFeeAmount')
            && request.resource.data.lockedProcessingFeeAmount is number
            && request.resource.data.lockedProcessingFeeAmount == request.resource.data.processingFeeAmount
          )
        )
        && (
          (!has('lockedHostTotalCharge') && !has('hostTotalCharge'))
          || (
            has('lockedHostTotalCharge')
            && has('hostTotalCharge')
            && request.resource.data.lockedHostTotalCharge is number
            && request.resource.data.lockedHostTotalCharge == request.resource.data.hostTotalCharge
          )
        );
    }

    function validFeeBreakdown() {
      return (
        !has('payBaseAmount')
        && !has('processingFeeRate')
        && !has('processingFeeAmount')
        && !has('hostTotalCharge')
      )
      || (
        has('payBaseAmount')
        && has('processingFeeRate')
        && has('processingFeeAmount')
        && has('hostTotalCharge')
        && request.resource.data.payBaseAmount is number
        && request.resource.data.payBaseAmount >= 0
        && request.resource.data.processingFeeRate is number
        && request.resource.data.processingFeeRate == 0.02
        && request.resource.data.processingFeeAmount is number
        && request.resource.data.processingFeeAmount >= 0
        && request.resource.data.hostTotalCharge is number
        && request.resource.data.hostTotalCharge >= request.resource.data.payBaseAmount
      );
    }

    // ─── Musicians ──────────────────────────────────────────────────
    match /musicians/{userId} {

      allow read: if isVerifiedAuth();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isVerifiedAuth()
          && request.resource.data.keys().hasOnly(['gigId', 'hostId', 'hostName', 'grade', 'feedback', 'createdAt'])
          && request.resource.data.keys().hasAll(['gigId', 'hostId', 'hostName', 'grade', 'createdAt'])
          && request.resource.data.hostId == request.auth.uid
          && request.resource.data.grade in ['AA','A','B','C','D','F','N']
          && isString('gigId', 100)
          && isOptionalString('feedback', 150)
          && isString('hostName', 100)
          && request.resource.data.createdAt is timestamp
          && exists(/databases/$(database)/documents/gigs/$(request.resource.data.gigId))
          && get(/databases/$(database)/documents/gigs/$(request.resource.data.gigId)).data.hostId == request.auth.uid
          && get(/databases/$(database)/documents/gigs/$(request.resource.data.gigId)).data.acceptedBy == userId
          && get(/databases/$(database)/documents/gigs/$(request.resource.data.gigId)).data.status == 'accepted'
          && (!('reviewed' in get(/databases/$(database)/documents/gigs/$(request.resource.data.gigId)).data)
              || get(/databases/$(database)/documents/gigs/$(request.resource.data.gigId)).data.reviewed != true);
        allow update, delete: if false;
      }

      allow create: if isOwner(userId)
        && hasOnlyKeys([
          'firstName', 'lastName', 'location', 'zip', 'payoutMethod',
          'stageName', 'instruments', 'rate', 'bio', 'payoutHandle',
          'blackoutDates', 'bookedDates', 'type', 'available',
          'city', 'state', 'lat', 'lng', 'genres', 'experience',
          'performerType', 'updatedAt', 'businessClassRequestedAt', 'businessClassActive'
        ])
        && isString('firstName', 50)
        && isString('lastName', 50)
        && isString('location', 100)
        && isZip('zip')
        && validPaymentMethodField('payoutMethod')
        && validPaymentHandle('payoutMethod', 'payoutHandle')
        && isOptionalString('stageName', 80)
        && isOptionalString('instruments', 200)
        && isOptionalString('rate', 100)
        && isOptionalString('bio', 1000)
        && isString('city', 100)
        && isString('state', 30)
        && validGenres()
        && validExperience()
        && (!has('performerType') || request.resource.data.performerType in ['musician', 'dj', 'photographer', 'cinematographer', 'model'])
        && validListSize('blackoutDates', 400)
        && validListSize('bookedDates', 120)
        && isOptionalNumberInRange('lat', -90, 90)
        && isOptionalNumberInRange('lng', -180, 180)
        && (!has('updatedAt') || request.resource.data.updatedAt is timestamp)
        && (!has('businessClassRequestedAt') || request.resource.data.businessClassRequestedAt is timestamp)
        && (!has('businessClassActive') || request.resource.data.businessClassActive == false)
        && request.resource.data.type == 'musician'
        && request.resource.data.available is bool;

      allow update: if isOwner(userId)
        && hasOnlyKeys([
          'firstName', 'lastName', 'location', 'zip', 'payoutMethod',
          'stageName', 'instruments', 'rate', 'bio', 'payoutHandle',
          'blackoutDates', 'bookedDates', 'type', 'available',
          'city', 'state', 'lat', 'lng', 'genres', 'experience',
          'performerType', 'updatedAt', 'overallGrade', 'reviewCount', 'businessClassRequestedAt', 'businessClassActive'
        ])
        && isString('firstName', 50)
        && isString('lastName', 50)
        && isString('location', 100)
        && isZip('zip')
        && validPaymentMethodField('payoutMethod')
        && validPaymentHandle('payoutMethod', 'payoutHandle')
        && isOptionalString('stageName', 80)
        && isOptionalString('instruments', 200)
        && isOptionalString('rate', 100)
        && isOptionalString('bio', 1000)
        && isString('city', 100)
        && isString('state', 30)
        && validGenres()
        && validExperience()
        && (!has('performerType') || request.resource.data.performerType in ['musician', 'dj', 'photographer', 'cinematographer', 'model'])
        && validListSize('blackoutDates', 400)
        && validListSize('bookedDates', 120)
        && isOptionalNumberInRange('lat', -90, 90)
        && isOptionalNumberInRange('lng', -180, 180)
        && (!has('updatedAt') || request.resource.data.updatedAt is timestamp)
        && (!has('businessClassRequestedAt') || request.resource.data.businessClassRequestedAt is timestamp)
        && isUnchanged('type')
        && request.resource.data.available is bool
        && sameOrAbsent('overallGrade')
        && sameOrAbsent('reviewCount')
        && sameOrAbsent('businessClassActive');

      allow delete: if false;
    }

    // ─── Hosts ──────────────────────────────────────────────────────
    match /hosts/{userId} {

      allow read: if isVerifiedAuth();

      allow create: if isOwner(userId)
        && hasOnlyKeys([
          'firstName', 'lastName', 'venueName', 'venueType', 'location', 'zip',
          'payMethod', 'phone', 'website', 'bio', 'budget', 'payHandle',
          'type', 'city', 'state', 'lat', 'lng', 'updatedAt'
        ])
        && isString('firstName', 50)
        && isString('lastName', 50)
        && isString('venueName', 100)
        && has('venueType')
        && validHostVenueType()
        && isString('location', 100)
        && isZip('zip')
        && validPaymentMethodField('payMethod')
        && validPaymentHandle('payMethod', 'payHandle')
        && isOptionalPhone('phone')
        && isOptionalUrl('website')
        && isOptionalString('bio', 1000)
        && isOptionalString('budget', 100)
        && isString('city', 100)
        && isString('state', 30)
        && isOptionalNumberInRange('lat', -90, 90)
        && isOptionalNumberInRange('lng', -180, 180)
        && (!has('updatedAt') || request.resource.data.updatedAt is timestamp)
        && request.resource.data.type == 'host';

      allow update: if isOwner(userId)
        && hasOnlyKeys([
          'firstName', 'lastName', 'venueName', 'venueType', 'location', 'zip',
          'payMethod', 'phone', 'website', 'bio', 'budget', 'payHandle',
          'type', 'city', 'state', 'lat', 'lng', 'updatedAt'
        ])
        && isString('firstName', 50)
        && isString('lastName', 50)
        && isString('venueName', 100)
        && has('venueType')
        && validHostVenueType()
        && isString('location', 100)
        && isZip('zip')
        && validPaymentMethodField('payMethod')
        && validPaymentHandle('payMethod', 'payHandle')
        && isOptionalPhone('phone')
        && isOptionalUrl('website')
        && isOptionalString('bio', 1000)
        && isOptionalString('budget', 100)
        && isString('city', 100)
        && isString('state', 30)
        && isOptionalNumberInRange('lat', -90, 90)
        && isOptionalNumberInRange('lng', -180, 180)
        && (!has('updatedAt') || request.resource.data.updatedAt is timestamp)
        && isUnchanged('type');

      allow delete: if false;
    }

    // ─── User Roles ─────────────────────────────────────────────────
    match /userRoles/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasOnly(['role', 'updatedAt'])
        && request.resource.data.role in ['musician', 'host']
        && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp);
      allow update: if isOwner(userId)
        && request.resource.data.keys().hasOnly(['role', 'updatedAt'])
        && request.resource.data.role in ['musician', 'host']
        && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp);
      allow delete: if false;
    }

    // ─── User Summaries ─────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && request.resource.data.keys().hasOnly([
          'uid', 'oneId', 'role', 'email', 'displayName', 'city', 'state', 'status',
          'profileComplete', 'payoutReady', 'authProvider', 'profileRoute', 'dashboardRoute',
          'authLastSignInAt', 'authLastSignOutAt', 'authLastPasswordResetAt',
          'updatedAt', 'createdAt'
        ])
        && isString('uid', 128)
        && request.resource.data.uid == userId
        && isOptionalString('oneId', 32)
        && request.resource.data.role in ['musician', 'host']
        && isOptionalString('email', 160)
        && isOptionalString('displayName', 80)
        && isOptionalString('city', 80)
        && isOptionalString('state', 40)
        && isOptionalString('status', 24)
        && (!has('profileComplete') || request.resource.data.profileComplete is bool)
        && (!has('payoutReady') || request.resource.data.payoutReady is bool)
        && isOptionalString('authProvider', 40)
        && isOptionalString('profileRoute', 120)
        && isOptionalString('dashboardRoute', 120)
        && (!has('authLastSignInAt') || request.resource.data.authLastSignInAt is timestamp)
        && (!has('authLastSignOutAt') || request.resource.data.authLastSignOutAt is timestamp)
        && (!has('authLastPasswordResetAt') || request.resource.data.authLastPasswordResetAt is timestamp)
        && (!has('updatedAt') || request.resource.data.updatedAt is timestamp)
        && (!has('createdAt') || request.resource.data.createdAt is timestamp);
      allow delete: if false;
    }

    // ─── Plaid Items (server-managed only) ──────────────────────────
    match /plaidItems/{userId} {
      allow read, write: if false;
    }

    // ─── Gigs ───────────────────────────────────────────────────────
    match /gigs/{gigId} {

      match /messages/{messageId} {
        allow read: if isVerifiedAuth()
          && exists(/databases/$(database)/documents/gigs/$(gigId))
          && get(/databases/$(database)/documents/gigs/$(gigId)).data.status == 'accepted'
          && (
            get(/databases/$(database)/documents/gigs/$(gigId)).data.hostId == request.auth.uid
            || get(/databases/$(database)/documents/gigs/$(gigId)).data.acceptedBy == request.auth.uid
          );

        allow create: if isVerifiedAuth()
          && exists(/databases/$(database)/documents/gigs/$(gigId))
          && get(/databases/$(database)/documents/gigs/$(gigId)).data.status == 'accepted'
          && request.resource.data.keys().hasOnly(['senderId', 'senderRole', 'text', 'createdAt'])
          && request.resource.data.keys().hasAll(['senderId', 'senderRole', 'text', 'createdAt'])
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.senderRole in ['host', 'musician']
          && isString('text', 600)
          && request.resource.data.createdAt is timestamp
          && (
            (request.resource.data.senderRole == 'host'
              && get(/databases/$(database)/documents/gigs/$(gigId)).data.hostId == request.auth.uid)
            ||
            (request.resource.data.senderRole == 'musician'
              && get(/databases/$(database)/documents/gigs/$(gigId)).data.acceptedBy == request.auth.uid)
          );

        allow update, delete: if false;
      }

      allow read: if isVerifiedAuth()
        && (
          resource.data.status == 'open'
          || resource.data.hostId == request.auth.uid
          || (('acceptedBy' in resource.data) && resource.data.acceptedBy == request.auth.uid)
        );

      allow create: if isVerifiedAuth()
        && hasHostProfile()
        && hasOnlyKeys([
          'hostId', 'venue', 'location', 'genre', 'pay', 'date', 'time',
          'notes', 'skillNeed', 'performerType', 'status', 'createdAt',
          'lat', 'lng', 'payBaseAmount', 'processingFeeRate',
          'processingFeeAmount', 'hostTotalCharge', 'offerExpiryHours', 'expiresOn'
        ])
        && request.resource.data.hostId == request.auth.uid
        && isString('venue', 100)
        && isString('location', 100)
        && isString('genre', 50)
        && isString('pay', 100)
        && isString('date', 20)
        && isString('time', 10)
        && isOptionalString('notes', 500)
        && isOptionalString('skillNeed', 120)
        && (!has('performerType') || request.resource.data.performerType in ['musician','dj','photographer','cinematographer','model','any'])
        && request.resource.data.status == 'open'
        && (!has('createdAt') || request.resource.data.createdAt is timestamp)
        && isOptionalNumberInRange('lat', -90, 90)
        && isOptionalNumberInRange('lng', -180, 180)
        && isOptionalNonNegativeNumber('offerExpiryHours')
        && isOptionalString('expiresOn', 40)
        && isOptionalNonNegativeNumber('payBaseAmount')
        && isOptionalNonNegativeNumber('processingFeeAmount')
        && isOptionalNonNegativeNumber('hostTotalCharge')
        && validFeeBreakdown();

      allow update: if isVerifiedAuth()
        && isUnchanged('hostId')
        && (
          (request.auth.uid == resource.data.hostId
            && hasHostProfile()
            && resource.data.status in ['open', 'cancelled']
            && request.resource.data.status in ['open', 'cancelled']
            && (
              request.resource.data.status == 'cancelled'
              ? sameOrAbsent('acceptedBy')
              : !('acceptedBy' in request.resource.data)
            )
            && !('acceptedAt' in request.resource.data)
            && !('lockedPay' in request.resource.data)
            && !('lockedDate' in request.resource.data)
            && !('lockedTime' in request.resource.data)
            && !('lockedLocation' in request.resource.data)
            && !('lockedProcessingFeeAmount' in request.resource.data)
            && !('lockedHostTotalCharge' in request.resource.data)
            && !('checkedInAt' in request.resource.data)
            && sameOrAbsent('passedBy')
            && sameOrAbsent('reviewed'))
          ||
          (request.auth.uid == resource.data.hostId
            && hasHostProfile()
            && resource.data.status == 'accepted'
            && request.resource.data.status == 'cancelled'
            && !('acceptedBy' in request.resource.data)
            && !('acceptedAt' in request.resource.data)
            && !('lockedPay' in request.resource.data)
            && !('lockedDate' in request.resource.data)
            && !('lockedTime' in request.resource.data)
            && !('lockedLocation' in request.resource.data)
            && !('lockedProcessingFeeAmount' in request.resource.data)
            && !('lockedHostTotalCharge' in request.resource.data)
            && !('checkedInAt' in request.resource.data)
            && sameOrAbsent('passedBy')
            && sameOrAbsent('reviewed')
            && gigCoreUnchanged())
          ||
          (request.auth.uid == resource.data.hostId
            && hasHostProfile()
            && resource.data.status == 'accepted'
            && request.resource.data.status == 'accepted'
            && request.resource.data.acceptedBy == resource.data.acceptedBy
            && request.resource.data.reviewed == true
            && (!('reviewed' in resource.data) || resource.data.reviewed != true)
            && sameOrAbsent('checkedInAt')
            && sameOrAbsent('passedBy')
            && gigCoreUnchanged())
          ||
          (hasMusicianProfile()
            && request.auth.uid != resource.data.hostId
            && resource.data.status == 'open'
            && request.resource.data.status == 'accepted'
            && request.resource.data.acceptedBy == request.auth.uid
            && validAcceptanceLock()
            && !('checkedInAt' in request.resource.data)
            && sameOrAbsent('passedBy')
            && sameOrAbsent('reviewed')
            && gigCoreUnchanged())
          ||
          (hasMusicianProfile()
            && request.auth.uid != resource.data.hostId
            && resource.data.status == 'accepted'
            && resource.data.acceptedBy == request.auth.uid
            && request.resource.data.status == 'accepted'
            && request.resource.data.acceptedBy == resource.data.acceptedBy
            && request.resource.data.checkedInAt is timestamp
            && (!('checkedInAt' in resource.data) || request.resource.data.checkedInAt == resource.data.checkedInAt)
            && sameOrAbsent('passedBy')
            && sameOrAbsent('reviewed')
            && gigCoreUnchanged())
          ||
          (hasMusicianProfile()
            && request.auth.uid != resource.data.hostId
            && resource.data.status == 'accepted'
            && resource.data.acceptedBy == request.auth.uid
            && request.resource.data.status == 'open'
            && !('acceptedBy' in request.resource.data)
            && !('acceptedAt' in request.resource.data)
            && !('lockedPay' in request.resource.data)
            && !('lockedDate' in request.resource.data)
            && !('lockedTime' in request.resource.data)
            && !('lockedLocation' in request.resource.data)
            && !('lockedProcessingFeeAmount' in request.resource.data)
            && !('lockedHostTotalCharge' in request.resource.data)
            && !('checkedInAt' in request.resource.data)
            && sameOrAbsent('passedBy')
            && sameOrAbsent('reviewed')
            && gigCoreUnchanged())
          ||
          (hasMusicianProfile()
            && request.auth.uid != resource.data.hostId
            && resource.data.status == 'open'
            && request.resource.data.status == 'open'
            && request.resource.data.passedBy is list
            && request.resource.data.passedBy.hasAll(resource.data.passedBy != null ? resource.data.passedBy : [])
            && request.resource.data.passedBy.hasAny([request.auth.uid])
            && sameOrAbsent('acceptedBy')
            && sameOrAbsent('reviewed')
            && gigCoreUnchanged())
        );

      allow delete: if isVerifiedAuth()
        && request.auth.uid == resource.data.hostId;
    }

  }
}
