{
  "name": "foxhub",
  "version": "0.1.0",
  "description": "FoxHub super-app foundation for local trust, messaging, payments, services, and mini-app experiences.",
  "author": "FoxHub",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "test": "node --test tests/*.test.mjs",
    "smoke:auth": "node scripts/firebase-auth-smoke.mjs",
    "smoke:founder:invite": "node scripts/founder-invite-smoke.mjs",
    "smoke:public": "npm run vite:build && node scripts/release-smoke.mjs",
    "smoke:live": "node scripts/live-smoke.mjs",
    "release:check": "npm test && npm run smoke:public && npm run build",
    "build": "next build",
    "start": "next start",
    "build:next:functions": "npm run build && node scripts/prepare-next-functions.mjs",
    "vite:dev": "vite",
    "vite:build": "vite build",
    "vite:preview": "vite preview",
    "clean": "rm -rf .next out dist .firebase release node_modules/.vite",
    "deploy:hosting": "npm run vite:build && npx firebase-tools deploy --only hosting --project foxhub-superapp",
    "deploy:next": "npm run build:next:functions && npx firebase-tools deploy --config firebase.next.json --only functions:nextApp,hosting --project foxhub-superapp",
    "mobile:sync-content": "node scripts/sync-mobile-content.mjs",
    "mobile": "npm run mobile:sync-content && npm --prefix mobile start",
    "mobile:ios": "npm run mobile:sync-content && npm --prefix mobile run ios",
    "mobile:android": "npm run mobile:sync-content && npm --prefix mobile run android",
    "mobile:web": "npm run mobile:sync-content && npm --prefix mobile run web",
    "mobile:smoke": "npm run mobile:sync-content && npm --prefix mobile run smoke",
    "mobile:ready:ios": "npm run mobile:sync-content && npm --prefix mobile run ready:ios",
    "desktop": "npm run vite:build && electron .",
    "dist:win": "npm run vite:build && electron-builder --win portable",
    "dist:win:installer": "npm run vite:build && electron-builder --win nsis",
    "package:software": "npm run dist:win"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@openfeature/web-sdk": "^1.7.3",
    "@sentry/react": "^10.48.0",
    "@stripe/react-stripe-js": "^6.1.0",
    "@stripe/stripe-js": "^9.1.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "browser-image-compression": "^2.0.2",
    "cmdk": "^1.1.1",
    "comlink": "^4.4.2",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.20",
    "dexie": "^4.4.2",
    "dompurify": "^3.3.3",
    "file-saver": "^2.0.5",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.8.0",
    "framer-motion": "^12.38.0",
    "fuse.js": "^7.3.0",
    "idb-keyval": "^6.2.2",
    "json-rules-engine": "^7.3.1",
    "jszip": "^3.10.1",
    "launchdarkly-react-client-sdk": "^3.9.0",
    "localforage": "^1.10.0",
    "minisearch": "^7.2.0",
    "nanoid": "^5.1.7",
    "next": "^14.2.35",
    "papaparse": "^5.5.3",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^15.0.0",
    "react-hotkeys-hook": "^5.2.4",
    "react-markdown": "^10.1.0",
    "react-plaid-link": "^4.1.1",
    "react-qr-code": "^2.0.18",
    "react-resizable-panels": "^4.10.0",
    "react-virtuoso": "^4.18.4",
    "remark-gfm": "^4.0.1",
    "rrule": "^2.8.1",
    "socket.io-client": "^4.8.3",
    "uuid": "^13.0.0",
    "wavesurfer.js": "^7.12.6",
    "web-vitals": "^5.2.0",
    "y-indexeddb": "^9.0.12",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.30",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.1",
    "axe-core": "^4.11.2",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "msw": "^2.13.2",
    "vite": "^5.4.1",
    "vitest": "^4.1.4"
  },
  "build": {
    "appId": "com.foxhub.desktop",
    "productName": "FoxHub",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "signAndEditExecutable": false,
      "artifactName": "FoxHub-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
