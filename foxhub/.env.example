# Next.js server backend env. Use one of the Firebase admin credential options.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_JSON=
FOXHUB_OPS_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRET=

# Live smoke checks. FOXHUB_AUTH_SMOKE_EMAILS accepts a comma-separated list.
FOXHUB_AUTH_SMOKE_EMAIL=
FOXHUB_AUTH_SMOKE_EMAILS=
FOXHUB_AUTH_SMOKE_PASSWORD=
